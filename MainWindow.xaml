<Window x:Class="GB2JIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GB2JIS"
        mc:Ignorable="d"
        Title="中文汉字和日文汉字互转" Loaded="Window_Loaded"
        Height="400" Width="720" MinWidth="720" MinHeight="400" >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width=".45*"/>
            <ColumnDefinition Width="96" MinWidth="120" MaxWidth="120"/>
            <ColumnDefinition Width=".45*"/>
        </Grid.ColumnDefinitions>
        <Label x:Name="SrcTextLabel" Grid.Column="0" Content="中文文本" Margin="8" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" />
        <TextBox x:Name="SrcText" Grid.Column="0" Margin="8, 36, 8, 8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="24" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
        <CheckBox x:Name="UseUnihanCheck" Grid.Column="1" Margin="8, 8, 8, 8" Width="96" Height="28" HorizontalAlignment="Center" VerticalAlignment="Top" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="Unihan 优先" IsChecked="True" />
        <Button x:Name="PasteText" Grid.Column="1" Margin="8, 44, 8, 8" Width="96" Height="28" HorizontalAlignment="Center" VerticalAlignment="Top" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="从剪贴板粘贴" Click="PasteText_Click" />
        <Button x:Name="SearchTextCN" Grid.Column="1" Margin="8, -76, 8, 8" Width="96" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="本地搜索中文" Click="ConvertText_Click" />
        <Button x:Name="ConvertTextC2J" Grid.Column="1" Margin="8, -8, 8, 8" Width="96" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="中文转为日文" Click="ConvertText_Click" />
        <Button x:Name="ConvertTextJ2C" Grid.Column="1" Margin="8, 72, 8, 8" Width="96" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="日文转为中文" Click="ConvertText_Click" />
        <Button x:Name="SearchTextJA" Grid.Column="1" Margin="8, 140, 8, 8" Width="96" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="本地搜索日文" Click="ConvertText_Click" />
        <Button x:Name="CopyText" Grid.Column="1" Margin="8,8,8,16" Width="96" Height="28" HorizontalAlignment="Center" VerticalAlignment="Bottom" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="复制到剪贴板" Click="CopyText_Click"/>
        <Label x:Name="DstTextLabel" Grid.Column="2" Content="日文文本" Margin="8" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" />
        <TextBox x:Name="DstText" Grid.Column="2" Margin="8, 36, 8, 8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="24" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>
